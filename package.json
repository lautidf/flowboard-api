  "description": "Backend of a multi-tenant system for managing teams, projects, and tasks with role-based access control.",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts,yaml --exec tsx src/server.ts",
    "build": "tsc",
