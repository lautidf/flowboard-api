generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(cuid())

  email String @unique
  passwordHash String
  name String

  memberships Membership[]
  tasksAssigned Task[] @relation("assigneeTasks")
  tasksCreated Task[] @relation("creatorTasks")
  invitationsReceived Invitation[] @relation("invitationsReceived")
  invitationsSent Invitation[] @relation("invitationsSent")
}

model Organization {
  id String @id @default(cuid())

  name String @unique

  memberships Membership[]
  projects Project[]
  invitations Invitation[]
}

enum MembershipRole {
  MEMBER
  ADMIN
}

model Membership {
  userId String
  organizationId String

  role MembershipRole
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([userId, organizationId])
}

model Invitation {
  invitedUserId String
  organizationId String

  senderId String
  role MembershipRole

  invitedUser User @relation("invitationsReceived", fields: [invitedUserId], references: [id], onDelete: Cascade)
  sender User @relation("invitationsSent", fields: [senderId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id ([invitedUserId, organizationId])
}


model Project {
  id String @id @default(cuid())

  name String
  organizationId String

  tasks Task[]

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

enum Status {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model Task {
  id String @id @default(cuid())

  title String
  description String?
  status Status
  priority Priority
  projectId String
  position Int
  creatorId String
  assigneeId String?
  
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User @relation("creatorTasks", fields: [creatorId], references: [id])
  assignee User? @relation("assigneeTasks", fields: [assigneeId], references: [id])
}